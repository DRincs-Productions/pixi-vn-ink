{
  "compilerOptions": {
    "target": "ESNext",
    "experimentalDecorators": true,
    "module": "commonjs",
    "paths": {
      "@/*": ["./src/*"],
      "@drincs/pixi-vn-ink/parser": ["./src/parser/index.ts"],
      "@drincs/pixi-vn-ink/mapper": ["./src/mapper/index.ts"]
    },
    "resolveJsonModule": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}
