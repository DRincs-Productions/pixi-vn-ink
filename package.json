{
  "name": "@drincs/pixi-vn-ink",
  "version": "1.0.5",
  "type": "module",
  "workspaces": [
    "playground"
  ],
  "description": "Pixi'VN gives you the ability to write your own narrative using Ink",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup --config tsup.config.ts",
    "postbuild": "node -e \"const fs=require('fs');fs.mkdirSync('dist/vite',{recursive:true});fs.copyFileSync('src/vite/client.d.ts','dist/vite/client.d.ts')\"",
    "playground:install": "npm install -w playground",
    "playground:dev": "npm run build && npm run dev -w playground",
    "playground:preview": "npm run build && npm run build -w playground && npm run preview -w playground",
    "lint": "biome lint",
    "check": "biome check",
    "format": "biome format --write",
    "test": "vitest",
    "docs": "typedoc"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.mjs",
      "require": "./dist/parser.cjs",
      "default": "./dist/parser.mjs"
    },
    "./mapper": {
      "types": "./dist/mapper.d.ts",
      "import": "./dist/mapper.mjs",
      "require": "./dist/mapper.cjs",
      "default": "./dist/mapper.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs",
      "default": "./dist/vite.mjs"
    },
    "./vite/client": {
      "types": "./dist/vite/client.d.ts"
    },
    "./vite-listener": {
      "types": "./dist/vite-listener.d.ts",
      "import": "./dist/vite-listener.mjs",
      "require": "./dist/vite-listener.cjs",
      "default": "./dist/vite-listener.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "parser": [
        "./dist/parser.d.ts"
      ],
      "mapper": [
        "./dist/mapper.d.ts"
      ],
      "vite": [
        "./dist/vite.d.ts"
      ],
      "vite/client": [
        "./dist/vite/client.d.ts"
      ],
      "vite-listener": [
        "./dist/vite-listener.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DRincs-Productions/pixi-vn-ink.git"
  },
  "author": "DRincs-Productions",
  "license": "LGPL-2.1",
  "bugs": {
    "url": "https://github.com/DRincs-Productions/pixi-vn-ink/issues"
  },
  "homepage": "https://pixi-vn.com/ink",
  "funding": "https://github.com/DRincs-Productions/pixi-vn?sponsor=1",
  "dependencies": {
    "@drincs/pixi-vn-json": "^1.13.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "inkjs": "2.4.0",
    "jsdom": "^29.1.1",
    "json5": "^2.2.3",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.16",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@drincs/pixi-vn": ">=1.8.0",
    "zod": ">=4.4.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "keywords": [
    "game",
    "ink",
    "js",
    "novel",
    "pixi",
    "pixi-js",
    "pixi-vn",
    "visual",
    "visual-novel",
    "vn"
  ]
}
